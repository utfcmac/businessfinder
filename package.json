{
  "name": "businessfinder",
  "version": "1.0.0",
  "description": "Find businesses with missing websites, outdated info via Google Places API",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "tsx src/index.ts",
    "server": "tsx src/server.ts",
    "setup:hooks": "bash scripts/setup-hooks.sh",
    "postinstall": "npm run setup:hooks"
  },
  "dependencies": {
    "better-sqlite3": "^11.7.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
